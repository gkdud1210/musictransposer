# ============================================================
#  ScoreShift — 환경 변수 설정
#  이 파일을 복사해서 .env 로 이름을 변경하고 값을 입력하세요
#  cp .env.example .env
# ============================================================

# OpenAI API 키 (필수: GPT-4 Vision 사용)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-your-openai-api-key-here

# 서버 설정 (선택)
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS 허용 출처 (선택, 기본: *)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
