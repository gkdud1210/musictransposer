{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 ScoreShift Backend 실행",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "jinja": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    }
  ]
}
